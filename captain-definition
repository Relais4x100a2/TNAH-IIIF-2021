{
  "schemaVersion": 2,
  "dockerfileLines": [
    "FROM nginx:alpine",
    "RUN printf 'server {\n  listen 80;\n  location / {\n    root /usr/share/nginx/html;\n    index index.html;\n    add_header Access-Control-Allow-Origin *;\n    types {\n      application/json json;\n      application/ld+json json;\n    }\n  }\n}' > /etc/nginx/conf.d/default.conf",
    "COPY . /usr/share/nginx/html",
    "EXPOSE 80"
  ]
}
